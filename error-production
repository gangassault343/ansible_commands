---
- hosts: all
  become: true

  tasks:
    - block:
        - name: Install Nginx
          apt:
            name: nginx
            state: present
        - name: start nginx
          service:
            name: nginx
            state: started
            enabled: yes
        - name: Install apache2
          apt:
            name: apache2
            state: present
            update_cache: yes

        - name: Start apache
          service:
            name: apache2
            state: started

        - name: Validate apache
          uri:
            url: http://localhost
            status_code: 200

      rescue:
        - name: Rollback - remove apache
          apt:
            name: apache2
            state: absent

        - name: Print rollback message
          debug:
            msg: "Rollback executed because apache failed"
